# Скопируйте в .env в корне сайта (не коммитьте)

# URL Worker после деплоя order-bot (обязательно для Telegram-бота)
VITE_ORDER_API_URL=https://napoleon-order-bot.YOUR_SUBDOMAIN.workers.dev/order

# Тот же секрет, что ORDER_SECRET у Worker (если задавали)
# VITE_ORDER_SECRET=change-me

# Google reCAPTCHA — https://www.google.com/recaptcha/admin
# 1) Score based (v3)  2) Checkbox (v2) — для картинок при подозрении
# VITE_RECAPTCHA_V3_SITE_KEY=
# VITE_RECAPTCHA_V2_SITE_KEY=

# PIN для локальной админки /admin.html (опционально)
# ADMIN_PIN=1234
